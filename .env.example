# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ─── NextAuth.js v5 ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# Full URL of your deployment (no trailing slash)
NEXTAUTH_URL="https://your-app.railway.app"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# From: https://resend.com → API Keys
AUTH_RESEND_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Formly <noreply@yourdomain.com>"

# ─── Meta / Facebook ──────────────────────────────────────────────────────────
# From: developers.facebook.com → App → Settings → Basic
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
# OAuth callback registered in Meta App Dashboard
META_REDIRECT_URI="https://your-app.railway.app/api/integrations/meta/callback"
# Arbitrary secret used to verify webhook events from Meta
META_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

# ─── ServiceTitan ─────────────────────────────────────────────────────────────
# From: developer.servicetitan.io → Apps → Your App
SERVICETITAN_CLIENT_ID="your-servicetitan-client-id"
SERVICETITAN_CLIENT_SECRET="your-servicetitan-client-secret"
# OAuth callback registered in ServiceTitan Developer Portal
SERVICETITAN_REDIRECT_URI="https://your-app.railway.app/api/integrations/servicetitan/callback"
# Your app's application key (tenant-specific)
SERVICETITAN_APP_KEY="your-servicetitan-app-key"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# From: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxxxxxxxxxx"
# From: dashboard.stripe.com → Developers → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
# Price IDs from Stripe Products (create in dashboard)
STRIPE_PRICE_STARTER="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_GROWTH="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_SCALE="price_xxxxxxxxxxxxxxxxxxxx"

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting tokens at rest. Generate with:
#   openssl rand -hex 32
ENCRYPTION_KEY="19e7e33be9ba1682faf7605881c0ad88ac20ee48088311ab466f41a05e018b5d"

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
# Railway Redis plugin provides REDIS_URL automatically
REDIS_URL="redis://localhost:6379"

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# From: account.mapbox.com → Tokens
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoieW91cnVzZXJuYW1lIiwiYSI6ImV4YW1wbGUifQ.example"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
